# Database
DATABASE_URL="mysql://root:password@localhost:3306/cloudmantou"

# Auth
AUTH_SECRET="replace-with-a-32-character-random-secret"
AUTH_URL="http://localhost:3000"

# Seed defaults (development)
# Admin: username admin / password admin123
SEED_ADMIN_PASSWORD="admin123"
SEED_USER_PASSWORD="test123"

# Optional cache/session store (启用后限流使用 Redis，多实例部署推荐)
REDIS_URL="redis://localhost:6379"

# 生产环境在反代后设为 true，才信任 x-forwarded-for 等 IP 头
TRUST_PROXY_HEADERS="false"

# 后台支付网关密钥加密（可选，默认回退 AUTH_SECRET）
SETTINGS_ENCRYPTION_KEY=""

# Card Secret Salt — 必填，用于卡密哈希。缺失时应用启动会报错。
# 生成方式：openssl rand -hex 32
CARD_SECRET_SALT="replace-with-a-random-64-char-hex-string"

# Payment providers
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_SELLER_ID=""
ALIPAY_NOTIFY_URL="https://example.com/api/payment/notify/alipay"
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""
WECHAT_V3_PUBLIC_KEY=""
WECHAT_V3_PLATFORM_SERIAL=""
WECHAT_NOTIFY_URL="https://example.com/api/payment/notify/wechat"

# Local uploads (default: public/uploads)
UPLOAD_DIR="public/uploads"

# Optional object storage (reserved, not wired yet)
OSS_REGION=""
OSS_ACCESS_KEY=""
OSS_SECRET_KEY=""
OSS_BUCKET=""

# Site
SITE_URL="https://cloudmantou.example"
SITE_NAME="CloudMantou"
