# Database
DATABASE_URL="mysql://root:password@localhost:3306/cloudmantou"

# Auth
AUTH_SECRET="replace-with-a-32-character-random-secret"
AUTH_URL="http://localhost:3000"

# Vault TOTP 二次验证（Authenticator 应用，base32 密钥）
# 生成：openssl rand -base64 20 | tr '+/' 'AB' | tr -d '=' | head -c 32
# VAULT_TOTP_SECRET="JBSWY3DPEHPK3PXP"

# Seed defaults (development)
# Admin: username admin / password admin123
SEED_ADMIN_PASSWORD="admin123"
SEED_USER_PASSWORD="test123"

# Optional cache/session store (启用后限流使用 Redis，多实例部署推荐)
REDIS_URL="redis://localhost:6379"
# 生产环境配置 REDIS_URL 后，API 限流在 Redis 不可用时 fail-closed（拒绝请求）
RATE_LIMIT_REQUIRE_REDIS="false"

# 生产环境在反代后设为 true，才信任 x-forwarded-for 等 IP 头
TRUST_PROXY_HEADERS="false"

# 后台支付网关密钥加密（必填，缺失时应用拒绝启动）
# 生成方式：openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY="replace-with-a-random-64-char-hex-string"

# 支付测试模式：仅当设为 true 时，后台 testMode 开关才会生效
PAYMENT_TEST_MODE="false"

# Card Secret Salt — 必填，用于卡密哈希。缺失时应用启动会报错。
# 生成方式：openssl rand -hex 32
CARD_SECRET_SALT="replace-with-a-random-64-char-hex-string"

# Payment providers
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""
ALIPAY_SELLER_ID=""
ALIPAY_ENV="sandbox"
ALIPAY_SANDBOX_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"
ALIPAY_NOTIFY_URL="https://example.com/api/payment/notify/alipay"
WECHAT_APP_ID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""
WECHAT_API_V3_KEY=""
WECHAT_V3_PUBLIC_KEY=""
WECHAT_V3_PLATFORM_SERIAL=""
WECHAT_NOTIFY_URL="https://example.com/api/payment/notify/wechat"

# Local uploads (default: public/uploads)
UPLOAD_DIR="public/uploads"
# 绝对路径上传目录时，需同时设置允许的根路径（如 Docker 卷 /var/data）
# UPLOAD_ALLOWED_ROOT="/var/data"

# 定时任务密钥（/api/cron/expire-orders 鉴权）
CRON_SECRET="replace-with-a-random-cron-secret"

# Optional object storage (reserved, not wired yet)
OSS_REGION=""
OSS_ACCESS_KEY=""
OSS_SECRET_KEY=""
OSS_BUCKET=""

# Site
NEXT_PUBLIC_SITE_URL="https://cloudmantoua.top"
SITE_URL="https://cloudmantoua.top"
SITE_NAME="馒头的博客"
